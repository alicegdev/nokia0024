datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  password         String
  username         String
  musiques         Musique[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  Contact          Contact[]
}

model Contact {
  id          Int     @id @default(autoincrement())
  firstName   String
  lastName    String
  phoneNumber String
  isFavorite  Boolean
  email       String  @unique
  userId      Int? // Peut être nul si le contact n'est pas un utilisateur de l'application
  user        User?   @relation(fields: [userId], references: [id])
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  sendDate   DateTime @default(now())
  senderId   Int
  receiverId Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Musique {
  id        Int      @id @default(autoincrement())
  trackName String
  artiste   String
  genre     String
  dateAdded DateTime
  userId    Int
  User      User     @relation(fields: [userId], references: [id])
}

model Game {
  id     Int     @id @default(autoincrement())
  name   String
  scores Score[]
}

model Score {
  id     Int  @id @default(autoincrement())
  score  Int
  gameId Int
  Game   Game @relation(fields: [gameId], references: [id])
}
