{
  "name": "src",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node build/app.js",
    "prisma:migrate": "npx prisma migrate dev --name init --schema src/prisma/schema.prisma",
    "prisma:generate": "npx prisma generate --schema src/prisma/schema.prisma",
    "server": "node src/app.ts",
    "clean": "rimraf build",
    "build": "npm run clean && tsc",
    "start-api": "npx prisma generate --schema src/prisma/schema.prisma && npx prisma migrate deploy --schema src/prisma/schema.prisma && node ./build/app.js",
    "dev": "concurrently \"npx tsc --watch\" \"node -q build/app.js\"",
    "test": "npm run clean && jest"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "bcrypt": "^5.1.1",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "~4.16.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "~1.9.1",
    "prisma": "^5.16.1",
    "rimraf": "^5.0.7",
    "socket.io": "^4.7.5",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.5.12",
    "@types/socket.io": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5"
  }
}
